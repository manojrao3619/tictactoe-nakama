{
  "compilerOptions": {
    "target": "es5",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "outDir": "./build",
    "rootDir": "./src",
    "typeRoots": ["./node_modules"]
  },
  "include": ["src/**/*"]
}